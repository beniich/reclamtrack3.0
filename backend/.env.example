# serveur
PORT=5001
NODE_ENV=development

# MongoDB (Requis sauf si ENABLE_DEMO=true)
MONGODB_URI=mongodb://localhost:27017/reclamtrack

# JWT
JWT_SECRET=your-very-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_user
SMTP_PASSWORD=your_password

# (Optionnel) Redis cache
REDIS_URL=redis://localhost:6379

# Mode Démo
ENABLE_DEMO=false
DEMO_ADMIN_EMAIL=admin@reclamtrack.com
DEMO_ADMIN_PASSWORD=Admin123!

# --- Phase 5: Billing & Security ---
INTERNAL_SECRET=reclamtrack-internal-strong-secret-2026
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- Phase 6: Industrialization (2FA, Webhooks, Reports) ---
# Clé maître pour chiffrer les secrets TOTP en base de données (32 bytes hex)
TOTP_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Clé pour signer les webhooks sortants si configuration globale
WEBHOOK_SIGNATURE_SECRET=your-webhook-secret
